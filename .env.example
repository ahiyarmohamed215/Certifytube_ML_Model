# OpenRouter (LLM for quiz generation)
OPENROUTER_API_KEY=your_openrouter_api_key_here
QUIZ_MODEL=deepseek/deepseek-r1-0528:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=CertifyTube ML Service

LLM_TIMEOUT_SECONDS=40
QUIZ_MAX_QUESTIONS=20
QUIZ_MAX_ATTEMPTS_PER_QUESTION=1
QUIZ_GENERATION_TIMEOUT_SECONDS=300

# MySQL (transcript cache)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=certifytube

# Transcript fetch proxy for production deployments
# Supported values: none, generic, webshare
TRANSCRIPT_PROXY_MODE=none
TRANSCRIPT_PROXY_HTTP_URL=
TRANSCRIPT_PROXY_HTTPS_URL=
TRANSCRIPT_WEBSHARE_PROXY_USERNAME=
TRANSCRIPT_WEBSHARE_PROXY_PASSWORD=
TRANSCRIPT_WEBSHARE_PROXY_LOCATIONS=us,sg
